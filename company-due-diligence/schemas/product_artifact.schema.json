{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdd.local/schemas/product_artifact.schema.json",
  "title": "ProductArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id", "schema_version", "company_id", "run_id", "source_id",
    "lineage", "source_context", "entities", "notes"
  ],
  "$defs": {
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_snapshot_id", "content_path", "locator", "snippet", "extraction_prompt"],
      "properties": {
        "source_snapshot_id": {"type": "string", "minLength": 1},
        "content_path": {"type": "string", "minLength": 1},
        "locator": {"type": "object", "minProperties": 1},
        "snippet": {"type": "string", "minLength": 1},
        "extraction_prompt": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {"name": {"type": "string"}, "version": {"type": "string"}}
        }
      }
    }
  },
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^art_[0-9a-z]{16}$"},
    "schema_version": {"type": "string"},
    "company_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "pattern": "^src_[0-9a-f]{16}$"},
    "lineage": {"$ref": "#/$defs/lineage"},
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_title", "section_path", "source_native_statement_name", "table_id", "page"],
      "properties": {
        "document_title": {"type": ["string", "null"]},
        "section_path": {"type": "array", "items": {"type": "string"}},
        "source_native_statement_name": {"type": ["string", "null"]},
        "table_id": {"type": ["string", "null"]},
        "page": {"type": ["integer", "null"]}
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entity_id", "entity_type", "source_native_name", "aliases",
          "source_native_category_path", "parent_entity_id", "display_order",
          "description_quote", "lifecycle_status", "geography_scope",
          "pricing_observations", "attributes", "normalized_candidate"
        ],
        "properties": {
          "entity_id": {"type": "string"},
          "entity_type": {
            "type": "string",
            "enum": ["product", "service", "tier", "bundle", "feature", "platform", "module"]
          },
          "source_native_name": {"type": "string"},
          "aliases": {"type": "array", "items": {"type": "string"}},
          "source_native_category_path": {"type": "array", "items": {"type": "string"}},
          "parent_entity_id": {"type": ["string", "null"]},
          "display_order": {"type": ["integer", "null"]},
          "description_quote": {"type": ["string", "null"]},
          "lifecycle_status": {"type": ["string", "null"]},
          "geography_scope": {"type": "array", "items": {"type": "string"}},
          "pricing_observations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["price_raw", "currency_reported", "billing_interval", "locator"],
              "properties": {
                "price_raw": {"type": "string"},
                "currency_reported": {"type": ["string", "null"]},
                "billing_interval": {"type": ["string", "null"]},
                "locator": {"type": "object", "minProperties": 1}
              }
            }
          },
          "attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name_native", "value_native", "locator"],
              "properties": {
                "name_native": {"type": "string"},
                "value_native": {"type": ["string", "null"]},
                "locator": {"type": "object", "minProperties": 1}
              }
            }
          },
          "normalized_candidate": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["family", "confidence"],
                "properties": {
                  "family": {"type": "string"},
                  "confidence": {"type": "number", "minimum": 0, "maximum": 1}
                }
              }
            ]
          }
        }
      }
    },
    "notes": {"type": ["string", "null"]}
  }
}
